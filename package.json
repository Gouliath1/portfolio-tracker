{
  "name": "portfolio-tracker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:web": "turbo run dev --filter=@portfolio/web",
    "dev:mobile": "turbo run dev --filter=@portfolio/mobile",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@portfolio/types --filter=@portfolio/utils --filter=@portfolio/core --filter=@portfolio/server",
    "build:web": "turbo run build --filter=@portfolio/web",
    "build:mobile": "turbo run build --filter=@portfolio/mobile",
    "start": "turbo run start --filter=@portfolio/web",
    "lint": "turbo run lint",
    "prebuild:mobile": "cd apps/mobile && CI=1 EXPO_USE_STATIC=0 npx expo prebuild --clean || echo \"Skipping Expo prebuild (requires network and platform tooling).\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "push": "./scripts/gitPush.sh",
    "setup": "node scripts/setup.js",
    "setup:unix": "./scripts/setup.sh",
    "setup:windows": "scripts/setup.bat"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^29.7.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4",
    "turbo": "^2.1.3",
    "typescript": "^5"
  }
}
