{
  "name": "@portfolio/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "./App.tsx",
  "scripts": {
    "dev": "npm run boot:sim && EXPO_USE_STATIC=0 expo start --clear --ios --non-interactive --port 8082",
    "build": "npm run boot:sim && EXPO_USE_STATIC=0 expo run:ios --device 'iPhone 16 Plus'",
    "lint": "expo lint",
    "android": "EXPO_USE_STATIC=0 expo run:android",
    "ios": "EXPO_USE_STATIC=0 expo run:ios",
    "boot:sim": "open -a 'Simulator.app' || true; xcrun simctl boot 'iPhone 16 Plus' || true"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@libsql/core": "^0.15.15",
    "@portfolio/core": "file:../../packages/core",
    "@portfolio/types": "file:../../packages/types",
    "expo": "^51.0.0",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-svg": "15.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/plugin-transform-typescript": "^7.28.0",
    "babel-preset-expo": "^11.0.0",
    "typescript": "~5.3.3"
  }
}
